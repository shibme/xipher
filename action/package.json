{
  "name": "xipher-action",
  "description": "This action downloads and sets up the Xipher CLI into GitHub Actions workflows",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "prepare": "ncc build index.js -o dist --source-map --license licenses.txt",
    "all": "npm run lint && npm run prepare"
  },
  "keywords": [
    "actions",
    "xipher",
    "cli",
    "cryptography",
    "setup"
  ],
  "homepage": "https://xipher.org",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shibme/xipher.git"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vercel/ncc": "^0.44.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0"
  },
  "overrides": {
    "minimatch": ">=10.2.5"
  }
}
